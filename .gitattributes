# ── Default: normalise line endings to LF on commit ─────────────────────────
* text=auto eol=lf

# ── Source code: force LF ────────────────────────────────────────────────────
*.ts    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# ── Documentation / markdown ─────────────────────────────────────────────────
*.md        text eol=lf
*.feature   text eol=lf

# ── Scripts ──────────────────────────────────────────────────────────────────
*.sh    text eol=lf
*.bash  text eol=lf

# ── Git configuration files ──────────────────────────────────────────────────
.gitignore      text eol=lf
.gitattributes  text eol=lf

# ── Binary files — managed by Git LFS ────────────────────────────────────────
*.png    filter=lfs diff=lfs merge=lfs -text
*.jpg    filter=lfs diff=lfs merge=lfs -text
*.jpeg   filter=lfs diff=lfs merge=lfs -text
*.gif    filter=lfs diff=lfs merge=lfs -text
*.webp   filter=lfs diff=lfs merge=lfs -text
*.svg    filter=lfs diff=lfs merge=lfs -text
*.ico    filter=lfs diff=lfs merge=lfs -text
*.pdf    filter=lfs diff=lfs merge=lfs -text
*.zip    filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.tgz    filter=lfs diff=lfs merge=lfs -text

# Blanket rule for docs/assets (catches any binary in that path)
docs/assets/** filter=lfs diff=lfs merge=lfs -text

# ── Diff drivers ─────────────────────────────────────────────────────────────
# Treat lockfiles as binary to suppress noisy diffs
bun.lockb -diff
